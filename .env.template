# UADE Teams Downloader — Configuracion
# Copiar a .env y editar segun tu entorno.
# Todas las variables son opcionales — el sistema auto-detecta lo que puede.

# --- Paths ---
# Carpeta base donde estan las materias (default: ~/UADE/4to cuatrimestre)
# UADE_BASE_DIR=/ruta/a/tus/materias

# --- Teams ---
# IDs de los equipos de Teams (separados por coma).
# Encontrar en la URL de Teams: ...Section_XXXXXX/...
# TEAM_PREFIXES=568898,561218,558193

# --- Whisper (transcripcion) ---
# Backend: mlx (macOS Apple Silicon), openai-whisper (cualquier OS)
# Si no se especifica, se auto-detecta segun SO.
# WHISPER_BACKEND=openai-whisper
# WHISPER_MODEL=medium
# LANGUAGE=es

# --- LLM (resumenes) ---
# Provider: claude-cli, gemini, ollama
# Si no se especifica, se auto-detecta (claude > gemini > ollama).
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# Para Gemini (gratis): obtener API key en https://aistudio.google.com
# GEMINI_API_KEY=tu_api_key_aca

# --- Estructura de carpetas (opcional) ---
# Si usas nombres distintos para las carpetas de cada materia.
# FOLDER_MATERIAL=01_Material_de_Clase
# FOLDER_APUNTES=02_Apuntes_Personales
# FOLDER_TP=03_Trabajos_Practicos
# FOLDER_EVAL=04_Evaluaciones
# FOLDER_GRABACION=05_Grabaciones
# FOLDER_EXTRA=06_Material_Extra
